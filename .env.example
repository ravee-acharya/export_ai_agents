# Copy this to .env and fill in your values.
# .env is gitignored and never committed.

# LLM provider (openrouter | anthropic | gemini | ollama)
EXPORT_AI_LLM=openrouter

# API keys — only the one matching EXPORT_AI_LLM is required
OPENROUTER_API_KEY=sk-or-your-key-here
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Database
POSTGRES_PASSWORD=exportai_dev
DATABASE_URL=postgresql+asyncpg://exportai:exportai_dev@localhost:5432/exportai

# Redis
REDIS_URL=redis://localhost:6379

# Session TTL in seconds (default: 24h)
SESSION_TTL_SECONDS=86400

# Prompt version (default: v1)
PROMPT_VERSION=v1
